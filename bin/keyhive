#!/usr/bin/env bash
set -euo pipefail

# `keyhive` is the operator-facing wrapper around the scanner, proxy, web UI,
# and diagnostics. Resolve the real script location so a /usr/local/bin symlink
# still controls whichever checkout installed it.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"
SCRIPTS_DIR="$ROOT_DIR/scripts"
DATA_DIR="$ROOT_DIR/data"
SYSTEMD_DIR="$ROOT_DIR/systemd"

SERVICE="${KEYHIVE_SERVICE:-api-maker-scheduler.service}"
PROXY_SERVICE="${KEYHIVE_PROXY_SERVICE:-keyhive-proxy.service}"
WEB_SERVICE="${KEYHIVE_WEB_SERVICE:-keyhive-web.service}"
PROXY_URL="${KEYHIVE_PROXY_URL:-http://127.0.0.1:8787}"
WEB_URL="${KEYHIVE_WEB_URL:-http://127.0.0.1:8080}"

HF_KEYS_JS="$SCRIPTS_DIR/hf_keys.js"
COUNT_KEYS_PY="$SCRIPTS_DIR/count_keys.py"
RUN_STATS_PY="$SCRIPTS_DIR/run_stats.py"
KEYS_FILE="$DATA_DIR/keys.txt"
COOKIE_FILE="$DATA_DIR/hc_cookie.json"
LOG_FILE="$ROOT_DIR/logs/keyhive-scanner.log"
RUN_STATS_FILE="$DATA_DIR/run_stats.json"

PYTHON_BIN="/usr/bin/python3"
if [ -x "$ROOT_DIR/.venv/bin/python" ]; then
  PYTHON_BIN="$ROOT_DIR/.venv/bin/python"
fi

NODE_BIN="$(command -v node || true)"

# When the shell is interactive, print colored status blocks. In non-TTY mode
# the wrapper falls back to plain text so logs stay readable.
if [ -t 1 ]; then
  BOLD="$(printf '\033[1m')"
  DIM="$(printf '\033[2m')"
  GREEN="$(printf '\033[32m')"
  CYAN="$(printf '\033[36m')"
  YELLOW="$(printf '\033[33m')"
  RED="$(printf '\033[31m')"
  RESET="$(printf '\033[0m')"
else
  BOLD=""
  DIM=""
  GREEN=""
  CYAN=""
  YELLOW=""
  RED=""
  RESET=""
fi

section() {
  printf "\n%s%s%s\n" "$BOLD" "$1" "$RESET"
}

row() {
  printf "  %s%-18s%s %s\n" "$CYAN" "$1" "$RESET" "$2"
}

usage() {
  # This is the canonical quick reference for the repo's operational surface.
  printf "%sKEYHIVE%s\n" "$BOLD" "$RESET"
  printf "API key automation + local AI proxy control\n"

  section "USAGE"
  row "keyhive" "Open interactive SSH-friendly menu"
  row "keyhive [cmd]" "Run scanner, proxy, and reporting commands"

  section "SCANNER"
  row "start" "Start background key scanner"
  row "stop" "Stop background key scanner"
  row "restart" "Restart background key scanner"
  row "status" "Show scanner state, key count, and cookie age"
  row "logs" "Show recent scanner logs"
  row "logs -f" "Follow scanner logs"
  row "logs 200" "Show last 200 scanner log lines"
  row "runs=1" "Run hf_keys.js manually N times"
  row "report" "Count saved keys and estimate capacity"

  section "PROXY"
  row "proxy start" "Start local AI proxy"
  row "proxy stop" "Stop local AI proxy"
  row "proxy restart" "Restart local AI proxy"
  row "proxy status" "Show proxy service status and health"
  row "proxy logs" "Show recent proxy logs"
  row "proxy logs -f" "Follow proxy logs"
  row "proxy stats" "Show proxy runtime stats"
  row "proxy fallback" "Show fallback provider status"
  row "proxy test" "Send a tiny test request through the proxy"

  section "WEB"
  row "web start" "Start KeyHive Web UI"
  row "web stop" "Stop KeyHive Web UI"
  row "web restart" "Restart KeyHive Web UI"
  row "web status" "Show Web UI service status and health"
  row "web logs" "Show recent Web UI logs"

  section "OTHER"
  row "doctor" "Run local diagnostics"
  row "tree" "Show the stripped-down repo layout"
  row "ai" "Dump complete system state for AI (JSON)"
  row "help" "Show this help"

  section "SERVICES"
  printf "  Scanner: %s\n" "$SERVICE"
  printf "  Proxy:   %s\n" "$PROXY_SERVICE"
  printf "  Web:     %s\n" "$WEB_SERVICE"

  section "PROJECT"
  printf "  %s\n" "$ROOT_DIR"
}

prompt_enter() {
  printf "\nPress Enter to continue..."
  IFS= read -r _ || true
}

run_menu_action() {
  set +e
  "$@"
  code="$?"
  set -e
  if [ "$code" -ne 0 ]; then
    printf "\nCommand exited with status %s\n" "$code"
  fi
  prompt_enter
}

scanner_menu() {
  while true; do
    clear 2>/dev/null || true
    printf "%sKEYHIVE / Scanner%s\n" "$BOLD" "$RESET"
    printf "1) Start\n2) Stop\n3) Restart\n4) Status\n5) Logs\n6) Follow logs\n7) Manual run once\n0) Back\n\n"
    printf "Choice: "
    IFS= read -r choice || return 0
    case "$choice" in
      1) run_menu_action start_service ;;
      2) run_menu_action stop_service ;;
      3) run_menu_action restart_service ;;
      4) run_menu_action show_status ;;
      5) run_menu_action show_logs ;;
      6) show_logs -f ;;
      7) run_menu_action run_manual 1 ;;
      0|"") return 0 ;;
      *) printf "Invalid choice: %s\n" "$choice"; prompt_enter ;;
    esac
  done
}

proxy_menu() {
  while true; do
    clear 2>/dev/null || true
    printf "%sKEYHIVE / Proxy%s\n" "$BOLD" "$RESET"
    printf "1) Start\n2) Stop\n3) Restart\n4) Status\n5) Logs\n6) Follow logs\n7) Stats\n8) Fallback\n9) Test\n0) Back\n\n"
    printf "Choice: "
    IFS= read -r choice || return 0
    case "$choice" in
      1) run_menu_action proxy_start ;;
      2) run_menu_action proxy_stop ;;
      3) run_menu_action proxy_restart ;;
      4) run_menu_action proxy_status ;;
      5) run_menu_action show_proxy_logs ;;
      6) show_proxy_logs -f ;;
      7) run_menu_action proxy_stats ;;
      8) run_menu_action proxy_fallback ;;
      9) run_menu_action proxy_test ;;
      0|"") return 0 ;;
      *) printf "Invalid choice: %s\n" "$choice"; prompt_enter ;;
    esac
  done
}

web_menu() {
  while true; do
    clear 2>/dev/null || true
    printf "%sKEYHIVE / Web UI%s\n" "$BOLD" "$RESET"
    printf "1) Start\n2) Stop\n3) Restart\n4) Status\n5) Logs\n6) Follow logs\n0) Back\n\n"
    printf "Choice: "
    IFS= read -r choice || return 0
    case "$choice" in
      1) run_menu_action web_start ;;
      2) run_menu_action web_stop ;;
      3) run_menu_action web_restart ;;
      4) run_menu_action web_status ;;
      5) run_menu_action show_web_logs ;;
      6) show_web_logs -f ;;
      0|"") return 0 ;;
      *) printf "Invalid choice: %s\n" "$choice"; prompt_enter ;;
    esac
  done
}

logs_menu() {
  while true; do
    clear 2>/dev/null || true
    printf "%sKEYHIVE / Logs%s\n" "$BOLD" "$RESET"
    printf "1) Scanner logs\n2) Follow scanner logs\n3) Proxy logs\n4) Follow proxy logs\n5) Web logs\n6) Follow web logs\n0) Back\n\n"
    printf "Choice: "
    IFS= read -r choice || return 0
    case "$choice" in
      1) run_menu_action show_logs ;;
      2) show_logs -f ;;
      3) run_menu_action show_proxy_logs ;;
      4) show_proxy_logs -f ;;
      5) run_menu_action show_web_logs ;;
      6) show_web_logs -f ;;
      0|"") return 0 ;;
      *) printf "Invalid choice: %s\n" "$choice"; prompt_enter ;;
    esac
  done
}

interactive_menu() {
  if [ ! -t 0 ]; then
    usage
    return 0
  fi

  while true; do
    clear 2>/dev/null || true
    printf "%sKEYHIVE%s\n" "$BOLD" "$RESET"
    printf "1) Scanner\n2) Proxy\n3) Web UI\n4) Reports\n5) Logs\n6) Status\n7) Help\n0) Exit\n\n"
    printf "Choice: "
    IFS= read -r choice || return 0
    case "$choice" in
      1) scanner_menu ;;
      2) proxy_menu ;;
      3) web_menu ;;
      4) run_menu_action run_report ;;
      5) logs_menu ;;
      6) run_menu_action show_status ;;
      7) run_menu_action usage ;;
      0|"") return 0 ;;
      *) printf "Invalid choice: %s\n" "$choice"; prompt_enter ;;
    esac
  done
}

need_project() {
  # Fail early if the repo path or scanner script is missing. Everything else
  # assumes the project root is sane.
  if [ ! -d "$ROOT_DIR" ]; then
    echo "✗ Project folder missing: $ROOT_DIR" >&2
    exit 1
  fi

  if [ ! -f "$HF_KEYS_JS" ]; then
    echo "✗ Missing scanner script: $HF_KEYS_JS" >&2
    exit 1
  fi
}

need_node() {
  if [ -z "$NODE_BIN" ]; then
    echo "✗ node not found in PATH" >&2
    exit 1
  fi
}

service_exists() {
  # The wrapper checks unit-file presence before calling systemctl so it can
  # print a useful install-path hint instead of a bare systemctl failure.
  systemctl list-unit-files "$SERVICE" >/dev/null 2>&1
}

proxy_service_exists() {
  systemctl list-unit-files "$PROXY_SERVICE" >/dev/null 2>&1
}

web_service_exists() {
  systemctl list-unit-files "$WEB_SERVICE" >/dev/null 2>&1
}

start_service() {
  if ! service_exists; then
    echo "✗ Systemd service not found: $SERVICE"
    echo "Expected service file around:"
    echo "  /etc/systemd/system/$SERVICE"
    echo "  $SYSTEMD_DIR/$SERVICE"
    exit 1
  fi

  # The stats file is created before the service starts so the scheduler has a
  # consistent counter file from the first boot.
  "$PYTHON_BIN" "$RUN_STATS_PY" ensure >/dev/null
  systemctl start "$SERVICE"
  echo "✓ keyhive scanner started"
  systemctl status "$SERVICE" --no-pager -l | sed -n '1,12p'
}

stop_service() {
  if ! service_exists; then
    echo "✗ Systemd service not found: $SERVICE"
    exit 1
  fi

  systemctl stop "$SERVICE"
  echo "✓ keyhive scanner stopped"
}

restart_service() {
  if ! service_exists; then
    echo "✗ Systemd service not found: $SERVICE"
    exit 1
  fi

  # Restarting the scanner also resets the since-restart stats bucket.
  "$PYTHON_BIN" "$RUN_STATS_PY" reset-since-restart >/dev/null
  systemctl restart "$SERVICE"
  echo "✓ keyhive scanner restarted"
  systemctl status "$SERVICE" --no-pager -l | sed -n '1,12p'
}

show_status() {
  # Report the live systemd state plus the local key/cookie/run files that the
  # scanner and proxy depend on.
  section "KEYHIVE SCANNER"
  printf "  Project: %-24s %s\n" "$ROOT_DIR" ""
  printf "  Service: %s\n\n" "$SERVICE"

  if service_exists; then
    active="$(systemctl is-active "$SERVICE" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$SERVICE" 2>/dev/null || true)"
    main_pid="$(systemctl show "$SERVICE" -p MainPID --value 2>/dev/null || true)"
    since="$(systemctl show "$SERVICE" -p ActiveEnterTimestamp --value 2>/dev/null || true)"

    printf "  %-16s %s\n" "Active:" "${active:-unknown}"
    printf "  %-16s %s\n" "Enabled:" "${enabled:-unknown}"
    printf "  %-16s %s\n" "Main PID:" "${main_pid:-unknown}"
    printf "  %-16s %s\n" "Since:" "${since:-unknown}"
  else
    printf "  %-16s %s\n" "Active:" "missing"
    printf "  %-16s %s\n" "Enabled:" "missing"
  fi

  section "KEYS"

  if [ -f "$KEYS_FILE" ]; then
    key_count="$(grep -cve '^\s*$' "$KEYS_FILE" || true)"
    printf "  %-16s %s\n" "File:" "$KEYS_FILE"
    printf "  %-16s %s\n" "Count:" "$key_count"
    printf "  %-16s %s\n" "Modified:" "$(date -d "@$(stat -c %Y "$KEYS_FILE")" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || stat -c %y "$KEYS_FILE")"
  else
    printf "  %-16s missing: %s\n" "File:" "$KEYS_FILE"
    printf "  %-16s 0\n" "Count:"
  fi

  section "COOKIE"

  if [ -f "$COOKIE_FILE" ]; then
    cookie_mtime="$(stat -c %Y "$COOKIE_FILE")"
    now="$(date +%s)"
    age_sec="$((now - cookie_mtime))"
    age_min="$((age_sec / 60))"
    age_hr="$((age_min / 60))"
    age_rem_min="$((age_min % 60))"

    printf "  %-16s %s\n" "File:" "$COOKIE_FILE"
    printf "  %-16s %s\n" "Modified:" "$(date -d "@$cookie_mtime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || stat -c %y "$COOKIE_FILE")"
    printf "  %-16s %sh %sm\n" "Age:" "$age_hr" "$age_rem_min"
  else
    printf "  %-16s missing: %s\n" "File:" "$COOKIE_FILE"
  fi

  "$PYTHON_BIN" "$RUN_STATS_PY" status
}

_show_proxy_stats() {
  # Display proxy statistics from the /stats endpoint.
  local body
  body="$(curl -fsS "$PROXY_URL/stats" 2>/dev/null || true)"
  if [ -z "$body" ]; then
    echo "  ✗ Cannot reach proxy at $PROXY_URL"
    return
  fi

  "$PYTHON_BIN" - "$body" <<'PY'
import json, sys, locale
try:
    locale.setlocale(locale.LC_NUMERIC, "")
except Exception:
    locale = None

data = json.loads(sys.argv[1])
p = data.get("proxy", {})

def fmt(n):
    if locale:
        return locale.format_string("%d", n, grouping=True)
    return str(n)

print(f"  {'Requests (restart):':<26} {fmt(p.get('restart', {}).get('requests', 0))}")
print(f"  {'Requests (all time):':<26} {fmt(p.get('all_time', {}).get('requests', 0))}")
print(f"  {'Successes (restart):':<26} {fmt(p.get('restart', {}).get('successes', 0))}")
print(f"  {'Successes (all time):':<26} {fmt(p.get('all_time', {}).get('successes', 0))}")
print(f"  {'Failures (restart):':<26} {fmt(p.get('restart', {}).get('failures', 0))}")
print(f"  {'Failures (all time):':<26} {fmt(p.get('all_time', {}).get('failures', 0))}")
print(f"  {'Tokens (restart):':<26} {fmt(p.get('restart', {}).get('total_tokens', 0))}")
print(f"  {'Tokens (all time):':<26} {fmt(p.get('all_time', {}).get('total_tokens', 0))}")
print(f"  {'Prompt tokens (restart):':<26} {fmt(p.get('restart', {}).get('prompt_tokens', 0))}")
print(f"  {'Prompt tokens (all time):':<26} {fmt(p.get('all_time', {}).get('prompt_tokens', 0))}")
print(f"  {'Completion tokens (restart):':<26} {fmt(p.get('restart', {}).get('completion_tokens', 0))}")
print(f"  {'Completion tokens (all time):':<26} {fmt(p.get('all_time', {}).get('completion_tokens', 0))}")
print(f"  {'Tool calls (restart):':<26} {fmt(p.get('restart', {}).get('tool_calls', 0))}")
print(f"  {'Tool calls (all time):':<26} {fmt(p.get('all_time', {}).get('tool_calls', 0))}")

rt = p.get("restart", {})
at = p.get("all_time", {})
avg_rt = rt.get("avg_tokens_per_request", 0)
avg_at = at.get("avg_tokens_per_request", 0)
print(f"  {'Avg tokens/req (restart):':<26} {avg_rt:.0f if avg_rt else '?'}")
print(f"  {'Avg tokens/req (all time):':<26} {avg_at:.0f if avg_at else '?'}")

uptime = p.get("uptime_seconds", 0)
if uptime > 0:
    hrs = int(uptime // 3600)
    mins = int((uptime % 3600) // 60)
    print(f"  {'Uptime:':<26} {hrs}h {mins}m")

print()
print(f"  {'Current provider:':<26} {data.get('current_provider', data.get('fallback', {}).get('current_provider', '?'))}")
print(f"  {'Fallback active:':<26} {'Yes' if data.get('fallback', {}).get('fallback_enabled', False) else 'No'}")

models = {}
for bucket in (rt, at):
    for m, c in bucket.get("models", {}).items():
        models[m] = models.get(m, 0) + c
if models:
    print(f"  {'Models used:':<26}")
    for m in sorted(models, key=models.get, reverse=True):
        print(f"    {m:<42} {fmt(models[m])}")
PY
}

show_logs() {
  lines="120"
  follow="false"

  if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--follow" ]; then
    follow="true"
  elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    lines="$1"
  fi

  if ! service_exists; then
    echo "✗ Systemd service not found: $SERVICE"
    exit 1
  fi

  if [ "$follow" = "true" ]; then
    journalctl -u "$SERVICE" -b -f -o cat
  else
    journalctl -u "$SERVICE" -b -n "$lines" -o cat --no-pager
  fi
}

show_proxy_logs() {
  lines="120"
  follow="false"

  if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--follow" ]; then
    follow="true"
  elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    lines="$1"
  fi

  if ! proxy_service_exists; then
    echo "✗ Systemd service not found: $PROXY_SERVICE"
    exit 1
  fi

  if [ "$follow" = "true" ]; then
    journalctl -u "$PROXY_SERVICE" -b -f -o cat
  else
    journalctl -u "$PROXY_SERVICE" -b -n "$lines" -o cat --no-pager
  fi
}

show_web_logs() {
  lines="120"
  follow="false"

  if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--follow" ]; then
    follow="true"
  elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    lines="$1"
  fi

  if ! web_service_exists; then
    echo "✗ Systemd service not found: $WEB_SERVICE"
    exit 1
  fi

  if [ "$follow" = "true" ]; then
    journalctl -u "$WEB_SERVICE" -b -f -o cat
  else
    journalctl -u "$WEB_SERVICE" -b -n "$lines" -o cat --no-pager
  fi
}

run_report() {
  if [ ! -f "$COUNT_KEYS_PY" ]; then
    echo "✗ Missing report script: $COUNT_KEYS_PY" >&2
    exit 1
  fi

  cd "$ROOT_DIR"
  "$PYTHON_BIN" "$COUNT_KEYS_PY"
}

parse_runs_amount() {
  # Support the slightly annoying historical command shapes used by this repo.
  raw="${1:-}"

  case "$raw" in
    runs=*)
      echo "${raw#runs=}"
      ;;
    --runs=*)
      echo "${raw#--runs=}"
      ;;
    --amount=*)
      echo "${raw#--amount=}"
      ;;
    --amount)
      echo "${2:-}"
      ;;
    "")
      echo "1"
      ;;
    *)
      echo "$raw"
      ;;
  esac
}

run_manual() {
  # Run the Node scanner directly outside systemd, then record each invocation
  # in the same stats file the scheduler uses.
  need_project
  need_node

  amount="$(parse_runs_amount "${1:-}" "${2:-}")"

  if ! [[ "$amount" =~ ^[0-9]+$ ]] || [ "$amount" -lt 1 ]; then
    echo "✗ Invalid run amount: $amount"
    echo "Use: keyhive runs=1"
    exit 1
  fi

  echo "=== KEYHIVE MANUAL RUN ==="
  echo "Runs: $amount"
  echo "Script: $HF_KEYS_JS"
  echo

  cd "$ROOT_DIR"

  for i in $(seq 1 "$amount"); do
    echo
    echo "=== RUN $i/$amount ==="
    tmp_log="$(mktemp)"
    set +e
    "$NODE_BIN" "$HF_KEYS_JS" 2>&1 | tee "$tmp_log"
    run_code="${PIPESTATUS[0]}"
    set -e
    run_result="$("$PYTHON_BIN" "$RUN_STATS_PY" record "$run_code" "$tmp_log")"
    rm -f "$tmp_log"
    if [ "$run_result" = "success" ]; then
      echo "=== manual run $i status: success ==="
    else
      echo "=== manual run $i status: failure ($run_result) ==="
    fi
    if [ "$run_code" -ne 0 ]; then
      exit "$run_code"
    fi
  done

  echo
  echo "✓ Manual run complete"
}

doctor_ok() {
  printf "  %s✓%s %s\n" "$GREEN" "$RESET" "$1"
}

doctor_warn() {
  printf "  %s!%s %s\n" "$YELLOW" "$RESET" "$1"
}

doctor_fail() {
  printf "  %s✗%s %s\n" "$RED" "$RESET" "$1"
}

env_value() {
  # Read a specific key from .env without sourcing the entire file.
  key="$1"
  if [ ! -f "$ROOT_DIR/.env" ]; then
    return
  fi
  "$PYTHON_BIN" - "$ROOT_DIR/.env" "$key" <<'PY'
import sys
from pathlib import Path

env_file = Path(sys.argv[1])
target = sys.argv[2]
for line in env_file.read_text().splitlines():
    if not line or line.lstrip().startswith("#") or "=" not in line:
        continue
    key, value = line.split("=", 1)
    if key == target:
        print(value)
        break
PY
}

mask_secret() {
  value="$1"
  if [ -z "$value" ]; then
    return
  fi
  "$PYTHON_BIN" - "$value" <<'PY'
import sys
value = sys.argv[1]
if len(value) <= 10:
    print(value[:2] + "..." + value[-2:])
else:
    print(value[:6] + "..." + value[-4:])
PY
}

json_field() {
  field="$1"
  "$PYTHON_BIN" - "$field" <<'PY'
import json
import sys

field = sys.argv[1]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(1)
value = data
for part in field.split("."):
    if isinstance(value, dict):
        value = value.get(part)
    else:
        value = None
if isinstance(value, bool):
    print("true" if value else "false")
elif value is not None:
    print(value)
PY
}

doctor_check_imports() {
  # Validate that the Python runtime can import the modules the service code
  # expects before someone starts the scanner and learns about it the hard way.
  "$PYTHON_BIN" - <<'PY'
mods = ["fastapi", "uvicorn", "httpx", "rich", "dotenv"]
missing = []
for mod in mods:
    try:
        __import__(mod)
    except Exception:
        missing.append(mod)
if missing:
    print(", ".join(missing))
    raise SystemExit(1)
PY
}

doctor_check_node_module() {
  module="$1"
  node -e "require.resolve('$module')" >/dev/null 2>&1
}

run_doctor() {
  # The doctor command is a local health check, not a service manager. It
  # checks files, deps, services, and proxy health in one pass.
  section "KEYHIVE DOCTOR"

  warnings=0
  failures=0

  if [ -d "$ROOT_DIR" ]; then doctor_ok "Project root: $ROOT_DIR"; else doctor_fail "Project root missing: $ROOT_DIR"; failures=$((failures + 1)); fi
  if [ -f "$ROOT_DIR/.env" ]; then doctor_ok ".env exists"; else doctor_fail ".env missing"; failures=$((failures + 1)); fi
  if [ -d "$ROOT_DIR/.venv" ]; then doctor_ok "Python venv exists"; else doctor_warn "Python venv missing"; warnings=$((warnings + 1)); fi

  if doctor_check_imports >/tmp/keyhive_doctor_imports 2>/dev/null; then
    doctor_ok "Python deps import: fastapi, uvicorn, httpx, rich, dotenv"
  else
    missing_imports="$(cat /tmp/keyhive_doctor_imports 2>/dev/null || true)"
    doctor_warn "Python deps missing: ${missing_imports:-unknown}"
    warnings=$((warnings + 1))
  fi

  if [ -n "$NODE_BIN" ]; then
    doctor_ok "Node available: $NODE_BIN"
    if doctor_check_node_module dotenv; then doctor_ok "Node dep: dotenv"; else doctor_warn "Node dep missing: dotenv"; warnings=$((warnings + 1)); fi
    if doctor_check_node_module playwright; then doctor_ok "Node dep: playwright"; else doctor_warn "Node dep missing: playwright"; warnings=$((warnings + 1)); fi
  else
    doctor_warn "Node not found"
    warnings=$((warnings + 1))
  fi

  chrome_bin="$(command -v google-chrome-stable || command -v google-chrome || command -v chromium || command -v chromium-browser || true)"
  if [ -n "$chrome_bin" ]; then doctor_ok "Chrome/Chromium: $chrome_bin"; else doctor_warn "Chrome/Chromium not found"; warnings=$((warnings + 1)); fi

  if [ -f "$KEYS_FILE" ]; then
    key_count="$(grep -cve '^\s*$' "$KEYS_FILE" || true)"
    doctor_ok "HF keys file: $KEYS_FILE"
    doctor_ok "HF keys: $key_count"
  else
    doctor_fail "HF keys file missing: $KEYS_FILE"
    failures=$((failures + 1))
  fi

  if [ -f "$COOKIE_FILE" ]; then doctor_ok "hCaptcha cookie file exists"; else doctor_warn "hCaptcha cookie file missing"; warnings=$((warnings + 1)); fi

  agentmail="$(env_value AGENTMAIL_API_KEY || true)"
  if [ -n "$agentmail" ]; then doctor_ok "AgentMail key configured: $(mask_secret "$agentmail")"; else doctor_warn "AgentMail key missing"; warnings=$((warnings + 1)); fi

  nvidia="$(env_value NVDA_KEY || true)"
  if [ -n "$nvidia" ]; then doctor_ok "NVIDIA key configured: $(mask_secret "$nvidia")"; else doctor_warn "NVIDIA key missing"; warnings=$((warnings + 1)); fi

  gmail_raw="$(env_value GMAIL_ACCOUNTS || true)"
  if [ -n "$gmail_raw" ]; then
    gmail_count="$(printf "%s" "$gmail_raw" | "$PYTHON_BIN" -c 'import json,sys; print(len(json.load(sys.stdin)))' 2>/dev/null || echo "invalid")"
    if [ "$gmail_count" = "invalid" ]; then
      doctor_warn "Gmail accounts JSON invalid"
      warnings=$((warnings + 1))
    else
      doctor_ok "Gmail accounts: $gmail_count"
    fi
  else
    doctor_warn "Gmail accounts missing"
    warnings=$((warnings + 1))
  fi

  if command -v systemctl >/dev/null 2>&1; then
    doctor_ok "systemd available"
    if service_exists; then doctor_ok "Scanner unit installed: $SERVICE"; else doctor_warn "Scanner unit missing: $SERVICE"; warnings=$((warnings + 1)); fi
    if proxy_service_exists; then doctor_ok "Proxy unit installed: $PROXY_SERVICE"; else doctor_warn "Proxy unit missing: $PROXY_SERVICE"; warnings=$((warnings + 1)); fi
    scanner_active="$(systemctl is-active "$SERVICE" 2>/dev/null || true)"
    proxy_active="$(systemctl is-active "$PROXY_SERVICE" 2>/dev/null || true)"
    if [ "$scanner_active" = "active" ]; then
      doctor_ok "Scanner service: active"
    else
      doctor_warn "Scanner service: ${scanner_active:-unknown}"
      warnings=$((warnings + 1))
    fi
    if [ "$proxy_active" = "active" ]; then
      doctor_ok "Proxy service: active"
    else
      doctor_warn "Proxy service: ${proxy_active:-unknown}"
      warnings=$((warnings + 1))
    fi
  else
    doctor_warn "systemd not available"
    warnings=$((warnings + 1))
  fi

  health="$(curl -fsS "$PROXY_URL/health" 2>/dev/null || true)"
  if [ -n "$health" ]; then
    doctor_ok "Proxy health: $(printf "%s" "$health" | json_field status 2>/dev/null || echo "ok")"
    provider="$(printf "%s" "$health" | json_field current_provider 2>/dev/null || true)"
    [ -n "$provider" ] && doctor_ok "Current provider: $provider"
  else
    doctor_warn "Proxy health unreachable: $PROXY_URL/health"
    warnings=$((warnings + 1))
  fi

  stats_json="$(curl -fsS "$PROXY_URL/stats" 2>/dev/null || true)"
  if [ -n "$stats_json" ]; then
    available="$(printf "%s" "$stats_json" | json_field keys_available 2>/dev/null || true)"
    fallback="$(printf "%s" "$stats_json" | json_field fallback_enabled 2>/dev/null || true)"
    nvidia_available="$(printf "%s" "$stats_json" | json_field nvidia_available 2>/dev/null || true)"
    provider="$(printf "%s" "$stats_json" | json_field current_provider 2>/dev/null || true)"
    enter_at="$(printf "%s" "$stats_json" | json_field fallback_enter_at 2>/dev/null || true)"
    exit_at="$(printf "%s" "$stats_json" | json_field fallback_exit_at 2>/dev/null || true)"
    exhausted="$(printf "%s" "$stats_json" | json_field exhausted_keys_this_runtime 2>/dev/null || true)"
    cooling="$(printf "%s" "$stats_json" | json_field keys_cooling_down 2>/dev/null || true)"
    last_reload="$(printf "%s" "$stats_json" | json_field last_reload 2>/dev/null || true)"
    [ -n "$available" ] && doctor_ok "Proxy HF usable keys: $available"
    [ -n "$fallback" ] && doctor_ok "Fallback enabled: $fallback"
    [ -n "$enter_at" ] && [ -n "$exit_at" ] && doctor_ok "Fallback config present: enter <= $enter_at, exit >= $exit_at"
    [ -n "$exit_at" ] && doctor_ok "Fallback exit threshold: $exit_at"
    [ -n "$nvidia_available" ] && doctor_ok "NVIDIA fallback available: $nvidia_available"
    [ -n "$provider" ] && doctor_ok "Proxy provider mode: $provider"
    [ "$provider" = "nvidia" ] && { doctor_warn "Proxy is using NVIDIA fallback because HF usable keys are ${available:-0}"; warnings=$((warnings + 1)); }
    [ -n "$exhausted" ] && doctor_ok "Exhausted HF keys removed this runtime: $exhausted"
    [ -n "$cooling" ] && doctor_ok "Rate-limited HF keys cooling down: $cooling"
    [ -n "$last_reload" ] && doctor_ok "Last key reload: $last_reload"
  else
    doctor_warn "Proxy stats unreachable: $PROXY_URL/stats"
    warnings=$((warnings + 1))
  fi

  proxy_host="$(env_value KEYHIVE_PROXY_HOST || true)"
  if [ -n "$proxy_host" ] && [ "$proxy_host" != "127.0.0.1" ]; then
    doctor_warn "Proxy host is not loopback: $proxy_host"
    warnings=$((warnings + 1))
  fi

  if [ "${ANTHROPIC_BASE_URL:-}" = "http://127.0.0.1:8787" ]; then
    doctor_ok "Claude env active: ANTHROPIC_BASE_URL"
  else
    doctor_warn "Claude env not sourced in current shell"
    warnings=$((warnings + 1))
  fi

  section "SUMMARY"
  printf "  Warnings: %s\n" "$warnings"
  printf "  Failures: %s\n" "$failures"
}

show_tree() {
  cd "$ROOT_DIR"
  if ! command -v tree >/dev/null 2>&1; then
    echo "✗ tree not found" >&2
    exit 1
  fi

  tree -a -I '.git|.agents|.codex|.env|.env.*|.venv|venv|env|node_modules|__pycache__|.pytest_cache|.mypy_cache|.ruff_cache|.cache|dist|build|*.egg-info|logs|data|profiles|.pair-programming-session.md|.plugin-config|.remember|*.log|fail_*.png|chrome-*.log'
}

proxy_start() {
  if ! proxy_service_exists; then
    echo "✗ Systemd service not found: $PROXY_SERVICE"
    echo "Expected service file around:"
    echo "  /etc/systemd/system/$PROXY_SERVICE"
    echo "  $SYSTEMD_DIR/$PROXY_SERVICE"
    exit 1
  fi

  systemctl start "$PROXY_SERVICE"
  echo "✓ keyhive proxy started"
  systemctl status "$PROXY_SERVICE" --no-pager -l | sed -n '1,12p'
}

proxy_stop() {
  if ! proxy_service_exists; then
    echo "✗ Systemd service not found: $PROXY_SERVICE"
    exit 1
  fi

  systemctl stop "$PROXY_SERVICE"
  echo "✓ keyhive proxy stopped"
}

proxy_restart() {
  if ! proxy_service_exists; then
    echo "✗ Systemd service not found: $PROXY_SERVICE"
    exit 1
  fi

  systemctl restart "$PROXY_SERVICE"
  echo "✓ keyhive proxy restarted"
  systemctl status "$PROXY_SERVICE" --no-pager -l | sed -n '1,12p'
}

curl_json() {
  url="$1"
  if command -v curl >/dev/null 2>&1; then
    body="$(curl -fsS "$url" 2>/dev/null || true)"
  else
    echo "✗ curl not found" >&2
    exit 1
  fi

  if [ -z "$body" ]; then
    echo "✗ Request failed: $url" >&2
    exit 1
  fi

  if "$PYTHON_BIN" -m json.tool >/dev/null 2>&1 <<<"$body"; then
    "$PYTHON_BIN" -m json.tool <<<"$body"
  else
    echo "$body"
  fi
}

proxy_status() {
  # The proxy status path shows both systemd state and the live /health payload.
  section "KEYHIVE PROXY"
  printf "  %-12s %s\n" "Service:" "$PROXY_SERVICE"
  printf "  %-12s %s\n\n" "URL:" "$PROXY_URL"

  if proxy_service_exists; then
    systemctl status "$PROXY_SERVICE" --no-pager -l | sed -n '1,12p'
  else
    printf "  %-12s missing\n" "Service:"
  fi

  section "HEALTH"
  curl_json "$PROXY_URL/health" || true
}

proxy_stats() {
  # This mirrors the proxy /stats endpoint so operators can inspect provider
  # routing without manually curling JSON.
  section "KEYHIVE PROXY STATS"
  body="$(curl -fsS "$PROXY_URL/stats" 2>/dev/null || true)"
  if [ -z "$body" ]; then
    echo "✗ Request failed: $PROXY_URL/stats" >&2
    exit 1
  fi

  "$PYTHON_BIN" - "$body" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
provider = data.get("current_provider", "unknown")
hf_keys = data.get("hf_usable_keys", data.get("keys_available", 0))
fallback = data.get("fallback_enabled", False)
nvidia = data.get("nvidia_available", False)

print(f"  {'Current provider:':<30} {provider}")
print(f"  {'HF usable keys:':<30} {hf_keys}")
print(f"  {'Fallback:':<30} {'enabled' if fallback else 'disabled'}")
print(f"  {'Fallback enter threshold:':<30} <= {data.get('fallback_enter_at', 0)}")
print(f"  {'Fallback exit threshold:':<30} >= {data.get('fallback_exit_at', 10)}")
print(f"  {'NVIDIA available:':<30} {str(nvidia).lower()}")
print(f"  {'NVIDIA model:':<30} {data.get('nvidia_model', 'unknown')}")
print(f"  {'Last key reload:':<30} {data.get('last_reload') or 'unknown'}")
print(f"  {'keys.txt mtime:':<30} {data.get('keys_file_mtime') or 'unknown'}")
print(f"  {'Exhausted removed runtime:':<30} {data.get('exhausted_keys_this_runtime', 0)}")
print(f"  {'Disabled removed runtime:':<30} {data.get('disabled_keys_this_runtime', 0)}")
print(f"  {'Cooling down:':<30} {data.get('keys_cooling_down', 0)}")
print(f"  {'Active requests:':<30} {data.get('active_requests', 0)}")

# Proxy statistics
p = data.get("proxy", {})
def fmt(n):
    return f"{n:,}" if isinstance(n, int) else str(n)
rt = p.get("restart", {})
at = p.get("all_time", {})
print()
print(f"  {'─' * 50}")
print(f"  {'PROXY STATISTICS':<30}")
print(f"  {'─' * 50}")
print(f"  {'Requests (restart):':<30} {fmt(rt.get('requests', 0))}")
print(f"  {'Requests (all time):':<30} {fmt(at.get('requests', 0))}")
print(f"  {'Prompt tokens (restart):':<30} {fmt(rt.get('prompt_tokens', 0))}")
print(f"  {'Prompt tokens (all time):':<30} {fmt(at.get('prompt_tokens', 0))}")
print(f"  {'Completion tokens (restart):':<30} {fmt(rt.get('completion_tokens', 0))}")
print(f"  {'Completion tokens (all time):':<30} {fmt(at.get('completion_tokens', 0))}")
print(f"  {'Total tokens (restart):':<30} {fmt(rt.get('total_tokens', 0))}")
print(f"  {'Total tokens (all time):':<30} {fmt(at.get('total_tokens', 0))}")
print(f"  {'Tool calls (restart):':<30} {fmt(rt.get('tool_calls', 0))}")
print(f"  {'Tool calls (all time):':<30} {fmt(at.get('tool_calls', 0))}")
PY
}

proxy_fallback() {
  # This is a human-friendly summary of the fallback decision state. It exists
  # because the raw stats JSON is accurate but not exactly pleasant.
  if ! command -v curl >/dev/null 2>&1; then
    echo "✗ curl not found" >&2
    exit 1
  fi

  body="$(curl -fsS "$PROXY_URL/stats" 2>/dev/null || true)"
  if [ -z "$body" ]; then
    echo "✗ Request failed: $PROXY_URL/stats" >&2
    exit 1
  fi

  "$PYTHON_BIN" - "$body" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
provider = data.get("current_provider", "unknown")
hf_keys = data.get("hf_usable_keys", data.get("keys_available", 0))
enabled = data.get("fallback_enabled", False)
nvidia = data.get("nvidia_available", False)
enter_at = data.get("fallback_enter_at", 0)
exit_at = data.get("fallback_exit_at", 10)
model = data.get("nvidia_model", "unknown")
reason = data.get("fallback_reason")
last_reload = data.get("last_reload") or "unknown"
keys_mtime = data.get("keys_file_mtime") or "unknown"
exhausted = data.get("exhausted_keys_this_runtime", 0)
disabled = data.get("disabled_keys_this_runtime", 0)
cooling = data.get("keys_cooling_down", 0)

print("KEYHIVE FALLBACK")
if provider == "nvidia":
    print("Current provider: NVIDIA fallback")
    print(f"Reason:           {reason or f'HF usable keys are {hf_keys}'}")
    print(f"HF usable keys:   {hf_keys}")
    print(f"Switch back at:   {exit_at} keys")
else:
    print("Current provider: Hugging Face")
    print(f"HF usable keys:   {hf_keys}")
    print(f"Fallback:         {'enabled' if enabled else 'disabled'}")
    print(f"NVIDIA:           {'available' if nvidia else 'unavailable'}")
    print(f"Enter fallback:   <= {enter_at} keys")
    print(f"Exit fallback:    >= {exit_at} keys")
    print(f"NVIDIA model:     {model}")
print(f"NVIDIA:           {'available' if nvidia else 'unavailable'}")
print(f"Last key reload:  {last_reload}")
print(f"keys.txt mtime:   {keys_mtime}")
print(f"Exhausted removed:{exhausted}")
print(f"Disabled removed: {disabled}")
print(f"Cooling down:     {cooling}")
PY
}

proxy_test() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "✗ curl not found" >&2
    exit 1
  fi

  payload='{"model":"default","messages":[{"role":"user","content":"Say hello from KeyHive proxy in one sentence."}],"max_tokens":64,"stream":false}'
  response="$(curl -fsS "$PROXY_URL/v1/chat/completions" \
    -H 'Content-Type: application/json' \
    -d "$payload" 2>/dev/null || true)"

  if [ -z "$response" ]; then
    echo "✗ Proxy test request failed: $PROXY_URL/v1/chat/completions" >&2
    exit 1
  fi

  section "KEYHIVE PROXY TEST"
  if "$PYTHON_BIN" -m json.tool >/dev/null 2>&1 <<<"$response"; then
    "$PYTHON_BIN" -m json.tool <<<"$response"
  else
    echo "$response"
  fi
}

proxy_cmd() {
  subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    start)
      proxy_start
      ;;
    stop)
      proxy_stop
      ;;
    restart)
      proxy_restart
      ;;
    status)
      proxy_status
      ;;
    logs)
      show_proxy_logs "${1:-}"
      ;;
    stats)
      proxy_stats
      ;;
    fallback)
      proxy_fallback
      ;;
    test)
      proxy_test
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "✗ Unknown proxy command: $subcmd"
      echo
      usage
      exit 1
      ;;
  esac
}


[Unit]
# Hosts the local OpenAI-compatible proxy that serves Hugging Face and NVIDIA
# completions out of the same stable 127.0.0.1 endpoint.
Description=KeyHive Local OpenAI-Compatible Proxy
After=network-online.target
Wants=network-online.target

[Service]
# The proxy is local-only, but it still needs the repo path, key file, and
# fallback provider configuration injected through environment variables.
Type=simple
User=root
WorkingDirectory=@PROJECT_DIR@
Environment=HOME=/root
Environment=PATH=@VENV_BIN@:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=KEYHIVE_PROXY_HOST=127.0.0.1
Environment=KEYHIVE_PROXY_PORT=8787
Environment=KEYHIVE_KEYS_FILE=@PROJECT_DIR@/data/keys.txt
Environment=KEYHIVE_PROXY_DEFAULT_PROVIDER=hf
Environment=KEYHIVE_PROXY_FALLBACK_PROVIDER=nvidia
Environment=KEYHIVE_FALLBACK_ENABLED=1
Environment=KEYHIVE_FALLBACK_PROVIDER=nvidia
Environment=KEYHIVE_FALLBACK_ENTER_AT=0
Environment=KEYHIVE_FALLBACK_EXIT_AT=10
Environment=KEYHIVE_HF_BASE_URL=https://router.huggingface.co/v1
Environment=KEYHIVE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
Environment=KEYHIVE_PROXY_DEFAULT_MODEL=zai-org/GLM-5.2
Environment=KEYHIVE_PROXY_NVIDIA_MODEL=moonshotai/kimi-k2.6
Environment=KEYHIVE_PROXY_RELOAD_SECONDS=5
Environment=KEYHIVE_PROXY_MAX_KEY_FAILOVERS=3
Environment=KEYHIVE_PROXY_REQUEST_TIMEOUT=300
Environment=KEYHIVE_PROXY_MAX_RETRIES=2
Environment=KEYHIVE_PROXY_DEBUG=0
ExecStart=@PYTHON_BIN@ -m proxy.keyhive_proxy
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Node ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment / secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Runtime data ───────────────────────────────────────────────────────────
# The scanner/proxy/web UI write these at runtime; they are local state, not
# source. Keep the data/ folder itself (via .gitkeep) but ignore its contents.
logs/
*.log
*.tmp
*.bak
*.backup
*.old
*.orig

data/keys.txt
data/hc_cookie.json
data/run_stats.json
data/run_stats.lock
data/.last_key_count
data/.agentmail_state.json

# Browser-strength checkpoints hold Gmail addresses and live browser cookies —
# sensitive session state that must never be committed.
data/browser_strength/

# ─── Browser / runtime state ────────────────────────────────────────────────
# profiles/ holds real Chrome browser profiles (cookies, history, sessions).
# It must stay on disk locally but must NEVER be tracked by Git.
profiles/
tmp/
.cache/
chrome-*/
chrome-profile-*/
playwright-report/
test-results/
fail_*.png

# ─── OS / editor junk ───────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# ─── Local AI/editor/plugin tool state ──────────────────────────────────────
# Generated by local tooling (Claude Code, pair-programming plugin, session
# summaries) — nothing to do with the project itself.
.agents/
.codex/
.plugin-config/
.remember/
.pair-programming-session.md
.session-summary.md

# ─── Keep folder structure ──────────────────────────────────────────────────
!data/.gitkeep